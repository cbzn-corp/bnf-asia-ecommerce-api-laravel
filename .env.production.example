# =============================================================================
# ecommerce-api-laravel — Laravel Cloud production environment
# Copy values into Laravel Cloud → Environment → Variables
# Run migrations via deploy command: php artisan migrate --force
# =============================================================================

APP_NAME="BNF Asia API"
APP_ENV=production
APP_DEBUG=false
APP_URL=https://api.yourdomain.com

LOG_CHANNEL=stderr
LOG_LEVEL=warning

# Laravel Cloud injects DB_* when you attach a Postgres database.
# For Supabase instead, set DB_URL to the pooler URL (port 6543):
# DB_URL=postgresql://postgres.[REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true

DB_CONNECTION=pgsql

SESSION_DRIVER=array
QUEUE_CONNECTION=database
CACHE_STORE=database

JWT_SECRET=generate-with-openssl-rand-base64-32
JWT_TTL=480

SUPABASE_URL=https://[PROJECT-REF].supabase.co
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=product-images

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=orders@yourdomain.com

PAYMONGO_SECRET_KEY=sk_live_
PAYMONGO_WEBHOOK_SECRET=
STRIPE_SECRET_KEY=sk_live_
STRIPE_WEBHOOK_SECRET=

STOREFRONT_REVALIDATE_SECRET=generate-with-openssl-rand-base64-32
STOREFRONT_URL=https://shop.yourdomain.com
ADMIN_URL=https://admin.yourdomain.com

# Run seed once after first deploy (via cloud run command or locally with prod DB_URL):
# SEED_ADMIN_EMAIL=you@yourdomain.com
# SEED_ADMIN_PASSWORD=generate-a-strong-password
