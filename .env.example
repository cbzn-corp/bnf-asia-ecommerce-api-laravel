APP_NAME="BNF Asia API"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=10

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=debug

# PostgreSQL (Supabase)
# - Migrations: use Supabase DIRECT URL (port 5432)
# - Runtime API: pooler URL (port 6543) is fine
DB_CONNECTION=pgsql
DB_URL=postgresql://postgres:postgres@localhost:5432/bnf_asia_ecommerce

SESSION_DRIVER=array
QUEUE_CONNECTION=sync

# API response cache (driver follows CACHE_STORE below)
API_CACHE_ENABLED=true
API_CACHE_TTL=60

# Local: file works without Redis. Production: use redis.
CACHE_STORE=file
# CACHE_STORE=redis
# REDIS_HOST=127.0.0.1
# REDIS_PORT=6379

# JWT (8h access tokens)
JWT_SECRET=change-this-to-a-long-random-string-in-production
JWT_TTL=480

# Supabase Storage (product/CMS images)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=product-images

# Email SMTP
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=orders@example.com

# PayMongo (Philippines)
PAYMONGO_SECRET_KEY=sk_test_your_paymongo_secret_key
PAYMONGO_WEBHOOK_SECRET=whsec_your_paymongo_webhook_secret

# Stripe (international)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret

# Storefront ISR revalidation (must match storefront REVALIDATE_SECRET)
STOREFRONT_REVALIDATE_SECRET=change-this-to-a-long-random-string

# Public app URLs (no trailing slash) — CORS, emails, payment return URLs
STOREFRONT_URL=http://localhost:3000
ADMIN_URL=http://localhost:3001

# Seed (run once: php artisan db:seed)
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=change-me-before-production
